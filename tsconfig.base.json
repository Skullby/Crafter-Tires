{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@crafter/database": ["packages/database/src/index.ts"],
      "@crafter/database/*": ["packages/database/src/*"],
      "@crafter/ui": ["packages/ui/src/index.ts"],
      "@crafter/ui/*": ["packages/ui/src/*"]
    }
  }
}
